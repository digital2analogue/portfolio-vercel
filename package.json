{
  "name": "portfolio-vercel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/check-contrast.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "check-contrast": "node scripts/check-contrast.mjs",
    "sync-tokens": "node scripts/sync-tokens.mjs",
    "deploy": "node scripts/deploy.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "prepare": "husky"
  },
  "dependencies": {
    "@digital2analogue2/parsimony": "^0.3.1",
    "@vercel/analytics": "^2.0.1",
    "next": "^16.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "{app,lib,components}/**/*.{ts,tsx,js,jsx}": "eslint"
  }
}
