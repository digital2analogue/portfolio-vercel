{
  "name": "portfolio-vercel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/check-contrast.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "check-contrast": "node scripts/check-contrast.mjs",
    "sync-tokens": "node scripts/sync-tokens.mjs",
    "render-diagrams": "node scripts/render-diagrams.mjs",
    "deploy": "node scripts/deploy.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "prepare": "husky"
  },
  "dependencies": {
    "@digital2analogue2/parsimony": "^0.5.0",
    "@vercel/analytics": "^2.0.1",
    "next": "^16.2.4",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "tailwindcss": "^4",
    "typescript": "^7",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "{app,lib,components}/**/*.{ts,tsx,js,jsx}": "eslint"
  }
}
